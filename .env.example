# API Keys and Secrets (get your own from the respective services)

# JWT Secret Key (generate a random string for production)
SECRET_KEY=your-secret-key-here-minimum-32-chars

# Groq AI API Key (Free tier available at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_api_key_here

# Cloudinary configuration for file storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: Virtual Try-On APIs
# FASHN_API_KEY=your_fashn_key_here
# FAL_API_KEY=your_fal_key_here
